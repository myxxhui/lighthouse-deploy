# [Ref: 03_00_数据库与存储就绪_设计] 连接信息仅通过环境变量注入，不硬编码
# 复制为 .env 后按需修改；用于 init-db.sh 与 00_ 验收
#
# 公网一键部署（ECS 有公网 IP）：docker compose up -d 后，在 ECS 安全组入方向放行 TCP 3000（前端），
# 访问 http://<公网IP>:3000 即可。无需改 compose；前端 /api 由容器内 nginx 代理到后端。

# PostgreSQL (L2 控制平面) — 必选
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lighthouse
POSTGRES_USER=lighthouse
POSTGRES_PASSWORD=lighthouse

# ClickHouse (L3 证据平面) — 可选，不设则 init-db 跳过 ClickHouse
# CLICKHOUSE_HOST=localhost
# CLICKHOUSE_PORT=9000

# ---------- 01_ 成本透视真实数据：云账单 ETL ----------
# 按实践文档执行：复制本文件为 .env（cp .env.example .env），再按单账号或多账号填写下方变量。
# 仅测试时临时填写；测试通过后务必删除 AK/SK 相关行并执行实践文档附录「使用后清除步骤」。
# 详见：lighthouse-doc/04_阶段规划与实践/Phase4_真实环境集成与交付/01_成本透视真实数据.md §3.3(3)(3a)

# 单账号（无后缀）：未配置任何带 SUFFIX 变量时使用
# ALIBABA_CLOUD_ACCESS_KEY_ID=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# CLOUD_BILLING_PROVIDER=aliyun

# 多环境/多账号（推荐：直接用环境名 POC/FAT/UAT/PROD 作为后缀，与 cost_env_account_config.environment 一致）
# 先配 cost_env_account_config 表（插入 environment 与 account_id），再为需要拉取账单的环境填写对应 AK/SK。
# .env 为键值对格式，不支持 YAML 集合；若需用 YAML 管理多环境凭证，可由部署脚本在启动前读取 YAML 并 export 为上述变量。
# ALIBABA_CLOUD_ACCESS_KEY_ID_POC=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET_POC=
# ALIBABA_CLOUD_ACCESS_KEY_ID_FAT=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET_FAT=
# ALIBABA_CLOUD_ACCESS_KEY_ID_UAT=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET_UAT=
# ALIBABA_CLOUD_ACCESS_KEY_ID_PROD=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET_PROD=
# 某环境为国际站时可选（该环境单独 endpoint）：
# CLOUD_BILLING_ENDPOINT_UAT=business.ap-southeast-1.aliyuncs.com
# 多账号时仍需启用：
# CLOUD_BILLING_PROVIDER=aliyun

# 国际站阿里云 BSS API（所有账号共用时可只设一条；单账号或多账号均可）
# CLOUD_BILLING_ENDPOINT=business.ap-southeast-1.aliyuncs.com

# ---------- 前端镜像构建（仅当改完前端代码后镜像仍为旧版时关注）----------
# 构建上下文：默认相对路径 ../lighthouse-src（相对 docker-compose 所在目录）。若 lighthouse-src 与 lighthouse-deploy 非同级目录，请设为本机绝对路径，例如：
# LIGHTHOUSE_SRC_PATH=/root/work/lighthouse/lighthouse-src
# 强制重建前端时脚本会设置 BUILD_TIME，无需手填。